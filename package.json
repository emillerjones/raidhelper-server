  "description": "RaidHelper - Server Repo\r //EMJ Initial set up\r Git Hub - Create Repo\r cd raidhelper-server\r npm init -y\r npm install express cors pg dotenv\r npm install --save-dev nodemon",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "dev": "node --watch --env-file=.env server.js",
